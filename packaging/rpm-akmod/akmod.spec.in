%define modname @MODNAME@
%global debug_package %{nil}

Name:           akmod-%{modname}
Version:        @VERSION@
Release:        1%{?dist}
Summary:        Akmod package for %{modname} kernel module
License:        GPLv2
URL:            https://github.com/BeardOverflow/msi-ec
Source0:        %{modname}-%{version}.tar.gz

BuildRequires:  gcc make kernel-devel kmodtool
Requires:       akmods
Requires:       %{modname}-kmod-common >= %{version}

%{expand:%(kmodtool --target %{_target_cpu} --repo %{?kmod_repo}%{!?kmod_repo:rpmfusion} --kmodname %{modname} 2>/dev/null || :)}

%description
This package provides the %{modname} kernel module through AKMOD.

%package -n %{modname}-kmod-common
Summary:        Common files for %{modname}
BuildArch:      noarch

%description -n %{modname}-kmod-common
Common files and configuration for %{modname}.

%prep
kmodtool --target %{_target_cpu} --repo %{?kmod_repo}%{!?kmod_repo:rpmfusion} --kmodname %{modname} > %{_builddir}/kmod-main.spec 2>/dev/null || :
%setup -q -n %{modname}-%{version}

%build

%install
install -D -m 0644 %{SOURCE0} %{buildroot}%{_usrsrc}/akmods/%{modname}-%{version}.tar.gz

install -D -m 0644 %{_builddir}/../../SPECS/akmod-%{modname}.spec %{buildroot}%{_usrsrc}/akmods/%{modname}.spec

install -p -D -m 0644 /dev/null %{buildroot}%{_sysconfdir}/modules-load.d/%{modname}.conf
echo %{modname} > %{buildroot}%{_sysconfdir}/modules-load.d/%{modname}.conf

%files
%{_usrsrc}/akmods/%{modname}-%{version}.tar.gz
%{_usrsrc}/akmods/%{modname}.spec

%files -n %{modname}-kmod-common
%{_sysconfdir}/modules-load.d/%{modname}.conf

%changelog
* @DATE@ @USER@ <@EMAIL@> - @VERSION@-1
- Make package